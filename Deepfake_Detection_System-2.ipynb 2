        "# F. Safe Dataset Wrapper (important!)\n",
        "## Why: some samples fail to load; wrapper retries nearby indices to avoid “DataLoader worker died” errors"
      ],
      "metadata": {
        "id": "isdS50JoQnhs"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "class SafeImageFolder(Dataset):\n",
        "\n",
        "    def __init__(self, root, transform=None):\n",
        "        self.ds = datasets.ImageFolder(str(root), transform=transform)\n",
        "        self.classes = self.ds.classes\n",
        "        self.class_to_idx = self.ds.class_to_idx\n",
        "\n",
        "    def __len__(self):\n",
        "        return len(self.ds)\n",
        "\n",
        "    def __getitem__(self, idx):\n",
        "        try:\n",
        "            return self.ds[idx]\n",
        "        except Exception:\n",
        "            # try a few next indices; if many corrupt, this still keeps moving\n",
        "            for k in range(1, 10):\n",
        "                j = (idx + k) % len(self.ds)\n",
        "                try:\n",
        "                    return self.ds[j]\n",
        "                except Exception:\n",
        "                    continue\n",
        "            # if still failing, raise (extremely rare)\n",
        "            raise\n",
        "\n",
        "# For preview: raw dataset without transforms\n",
        "raw_ds = SafeImageFolder(imagefolder_root, transform=None)\n",
        "# For training: transformed dataset\n",
        "full_ds = SafeImageFolder(imagefolder_root, transform=train_tfms)\n",
        "\n",
        "print(\"Classes:\", raw_ds.classes)\n",
        "print(\"class_to_idx:\", raw_ds.class_to_idx)\n",
        "print(\"Total images:\", len(raw_ds))\n",
        "\n",
        "# Positive class: \"fake\" if present\n",
        "class_to_idx = raw_ds.class_to_idx\n",
        "idx_to_class = {v:k for k,v in class_to_idx.items()}\n",
        "POS_CLASS_IDX = class_to_idx[\"fake\"] if \"fake\" in class_to_idx else 1\n",
        "print(\"Positive class used:\", idx_to_class.get(POS_CLASS_IDX, POS_CLASS_IDX))"

        "# E. Transforms\n",
        "\n",
        "## train transforms include resize + random horizontal flip + normalize\n",
        "## eval transforms are deterministic (no augmentation)"
      ],
      "metadata": {
        "id": "-gzOWiHWoi2T"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import torch\n",
        "from torchvision import datasets, transforms\n",
        "\n",
        "img_size = 224\n",
        "\n",
        "train_tfms = transforms.Compose([\n",
        "    transforms.Resize((img_size, img_size)),\n",
        "    transforms.RandomHorizontalFlip(p=0.5),\n",
        "    transforms.ToTensor(),\n",
        "    transforms.Normalize([0.485,0.456,0.406],[0.229,0.224,0.225]),\n",
        "])\n",
        "\n",
        "\n",
        "eval_tfms = transforms.Compose([\n",
        "    transforms.Resize((img_size, img_size)),\n",
        "    transforms.ToTensor(),\n",
        "    transforms.Normalize([0.485,0.456,0.406],[0.229,0.224,0.225]),\n",
        "])\n",
        "\n",
        "\n",
        "raw_ds  = datasets.ImageFolder(str(imagefolder_root), transform=None)\n",
        "full_ds = datasets.ImageFolder(str(imagefolder_root), transform=train_tfms)\n",
        "\n",
        "print(\"Classes:\", raw_ds.classes)\n",
        "print(\"class_to_idx:\", raw_ds.class_to_idx)\n",
        "print(\"Total images:\", len(raw_ds))"
      ],

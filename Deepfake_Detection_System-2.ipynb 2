    {
      "cell_type": "code",
      "source": [
        "@torch.no_grad()\n",
        "def evaluate(model, loader):\n",
        "    model.eval()\n",
        "    criterion = nn.CrossEntropyLoss()\n",
        "\n",
        "    all_probs, all_preds, all_targets = [], [], []\n",
        "    total_loss, total_seen = 0.0, 0\n",
        "\n",
        "    for x, y in loader:\n",
        "        x = x.to(device, non_blocking=True)\n",
        "        y = y.to(device, non_blocking=True)\n",
        "\n",
        "        logits = model(x)\n",
        "        loss = criterion(logits, y)\n",
        "\n",
        "        probs = torch.softmax(logits, dim=1)[:, POS_CLASS_IDX]\n",
        "        preds = torch.argmax(logits, dim=1)\n",
        "\n",
        "        bs = x.size(0)\n",
        "        total_loss += loss.item() * bs\n",
        "        total_seen += bs\n",
        "\n",
        "        all_probs.append(probs.detach().cpu().numpy())\n",
        "        all_preds.append(preds.detach().cpu().numpy())\n",
        "        all_targets.append(y.detach().cpu().numpy())\n",
        "\n",
        "    all_probs = np.concatenate(all_probs)\n",
        "    all_preds = np.concatenate(all_preds)\n",
        "    all_targets = np.concatenate(all_targets)\n",
        "\n",
        "    # Binary labels for positive class\n",
        "    y_bin = (all_targets == POS_CLASS_IDX).astype(int)\n",
        "    preds_bin = (all_preds == POS_CLASS_IDX).astype(int)\n",
        "\n",
        "    acc = accuracy_score(y_bin, preds_bin)\n",
        "    f1  = f1_score(y_bin, preds_bin)\n",
        "    prec = precision_score(y_bin, preds_bin, zero_division=0)\n",
        "    rec  = recall_score(y_bin, preds_bin, zero_division=0)\n",
        "\n",
        "    try:\n",
        "        auc_val = roc_auc_score(y_bin, all_probs)\n",
        "    except ValueError:\n",
        "        auc_val = float(\"nan\")\n",
        "\n",
        "    cm = confusion_matrix(y_bin, preds_bin)\n",
        "    avg_loss = total_loss / max(total_seen, 1)\n",
        "\n",
        "    return {\"loss\": avg_loss, \"acc\": acc, \"f1\": f1, \"precision\": prec, \"recall\": rec, \"auc\": auc_val, \"cm\": cm}\n",
        "\n",
        "@torch.no_grad()\n",
        "def collect_preds(model, loader):\n",
        "    model.eval()\n",
        "    probs_list, y_list = [], []\n",
        "    for x, y in loader:\n",
        "        x = x.to(device, non_blocking=True)\n",
        "        logits = model(x)\n",
        "        probs = torch.softmax(logits, dim=1)[:, POS_CLASS_IDX]\n",
        "        probs_list.append(probs.cpu().numpy())\n",
        "        y_list.append(y.numpy())\n",
        "    probs = np.concatenate(probs_list)\n",
        "    y = np.concatenate(y_list)\n",
        "    y_bin = (y == POS_CLASS_IDX).astype(int)\n",
        "    return probs, y_bin\n"
      ],

        "def find_imagefolder_root(root: Path):\n",
        "    img_ext = {\".jpg\", \".jpeg\", \".png\", \".webp\", \".bmp\"}\n",
        "\n",
        "    def looks_like_imagefolder(p: Path):\n",
        "        if not p.is_dir(): return False\n",
        "        subdirs = [x for x in p.iterdir() if x.is_dir()]\n",
        "        if len(subdirs) < 2: return False\n",
        "        # must contain at least one image in at least one subdir\n",
        "        for sd in subdirs:\n",
        "            for f in sd.rglob(\"*\"):\n",
        "                if f.suffix.lower() in img_ext:\n",
        "                    return True\n",
        "        return False\n",
        "\n",
        "    if looks_like_imagefolder(root):\n",
        "        return root\n",
        "\n",
        "    candidates = []\n",
        "    for p in root.rglob(\"*\"):\n",
        "        if p.is_dir() and looks_like_imagefolder(p):\n",
        "            candidates.append(p)\n",
        "\n",
        "    if not candidates:\n",
        "        return None\n",
        "\n",
        "    candidates.sort(key=lambda p: len(p.parts))\n",
        "    return candidates[0]\n",
        "\n",
        "imagefolder_root = find_imagefolder_root(DATA_ROOT)\n",
        "print(\"Detected imagefolder_root:\", imagefolder_root)\n",
        "\n",
        "if imagefolder_root is None:\n",
        "    raise RuntimeError(\n",
        "        f\"Could not detect ImageFolder root under: {DATA_ROOT}\\n\"\n",
        "        f\"Inspect folders with:\\n!find {DATA_ROOT} -maxdepth 4 -type d | head -n 200\"\n",
        "    )"
      ],
